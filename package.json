{
  "name": "discord-codex",
  "version": "1.0.0",
  "description": "Discord bot powered by Codex SDK",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsx esbuild.config.ts",
    "dev": "tsx watch src/index.ts",
    "lint": "biome lint ./src",
    "fmt": "biome format --write ./src",
    "check": "biome check ./src && tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@chat-adapter/discord": "^4.26.0",
    "@chat-adapter/state-memory": "^4.26.0",
    "@hono/node-server": "^2.0.0",
    "@noble/ed25519": "^3.1.0",
    "@openai/codex-sdk": "^0.125.0",
    "discord-api-types": "^0.38.47",
    "hono": "^4.12.15",
    "openai": "^6.35.0",
    "pino": "^10.3.1",
    "redis": "^5.12.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
